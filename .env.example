# Gemini / Google AI (requerido para análisis IA)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Modelo Gemini (opcional)
NEURAUDIT_GEMINI_MODEL=gemini-2.5-flash

# Servicio ADK FastAPI interno (Next.js → ADK → Gemini → Fallback)
NEURAUDIT_ADK_ANALYZE_URL=http://127.0.0.1:8001/analyze

# Caché de investigaciones en memoria (ms, default 30 min)
NEURAUDIT_CACHE_TTL_MS=1800000

# Concurrencia máxima de fetches a datos.gov.co (1-13, default 4)
NEURAUDIT_FETCH_CONCURRENCY=4

# URL pública de la app (diagnóstico /api/system/status)
NEXT_PUBLIC_APP_URL=http://localhost:3000
