# Gemini / Google AI (required)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Model
NEURAUDIT_GEMINI_MODEL=gemini-2.5-flash

# ADK Analyze microservice (Next.js → deep analysis fallback)
NEURAUDIT_ADK_ANALYZE_URL=http://127.0.0.1:8001/analyze

# ADK Agent service (primary: User → ADK → Elastic MCP → Gemini)
NEURAUDIT_ADK_AGENT_URL=http://127.0.0.1:8080

# NeurAudit API called by ADK tools
NEURAUDIT_API=http://127.0.0.1:3000/api/agent/search

# Elastic — Elasticsearch SDK (fallback)
ELASTIC_ENDPOINT=https://your-deployment.es.us-central1.gcp.cloud.es.io
ELASTIC_API_KEY=

# Elastic — Agent Builder MCP (required for hackathon compliance)
# Option A: full MCP URL
ELASTIC_MCP_URL=https://your-deployment.kb.us-central1.gcp.cloud.es.io/api/agent_builder/mcp
# Option B: Kibana base URL (MCP path appended automatically)
ELASTIC_KIBANA_URL=https://your-deployment.kb.us-central1.gcp.cloud.es.io
ELASTIC_MCP_INDEX=secop-contratos

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEURAUDIT_CACHE_TTL_MS=1800000
NEURAUDIT_FETCH_CONCURRENCY=4

# GCP deploy (deploy-gcp.sh)
GCP_PROJECT_ID=
GCP_REGION=us-central1
